ANTROCARE_ADMIN_KEY=replace-with-local-admin-password
ANTROCARE_ADMIN_EMAIL=sandeepkumar.parangi0305@gmail.com
ANTROCARE_LOW_STOCK_THRESHOLD=5
ANTROCARE_MAIL_ALERTS_ENABLED=true

# Google OAuth2. Create these in Google Cloud Console.
ANTROCARE_OAUTH2_ENABLED=true
ANTROCARE_FRONTEND_URL=http://127.0.0.1:5175
SPRING_SECURITY_OAUTH2_CLIENT_REGISTRATION_GOOGLE_CLIENT_ID=replace-with-google-client-id
SPRING_SECURITY_OAUTH2_CLIENT_REGISTRATION_GOOGLE_CLIENT_SECRET=replace-with-google-client-secret

# For Gmail, use your Gmail address and a Gmail App Password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=sandeepkumar.parangi0305@gmail.com
SMTP_PASSWORD=replace-with-gmail-app-password
SMTP_AUTH=true
SMTP_STARTTLS_ENABLE=true
SMTP_STARTTLS_REQUIRED=true
